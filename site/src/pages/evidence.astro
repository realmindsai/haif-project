  </ol>

  <style>
    .reference-list {
      padding-left: var(--spacing-lg);
    }
    .reference-list li {
      margin-bottom: var(--spacing-md);
      line-height: 1.55;
      font-size: 0.92rem;
    }
    .reference-list em {
      font-style: italic;
    }
  </style>
</BaseLayout>
