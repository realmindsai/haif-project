---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils';
---

<BaseLayout
  title="Contact"
  description="Contact the Hospital Acupuncture Implementation Framework (HAIF) team at RMIT University."
  lastReviewed="April 2026"
>
  <h1>Contact Us</h1>

  <p>
    Have a question about the Hospital Acupuncture Implementation Framework?
    We welcome enquiries from clinicians, administrators, researchers, and
    acupuncture practitioners interested in hospital-based implementation.
  </p>

  <div class="bottom-line">
    <strong>Get in Touch</strong>
    <p>
      Email: <strong>contact [at] hospitalacupuncture.com</strong>
    </p>
    <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0;">
      Please allow up to five business days for a response. For urgent clinical
      questions, consult your local hospital guidelines and clinical governance team.
    </p>
  </div>

  <h2>What We Can Help With</h2>
  <ul>
    <li>Questions about applying the HAIF framework at your institution</li>
    <li>Requests for collaboration or research partnerships</li>
    <li>Feedback on framework content or evidence summaries</li>
    <li>Media and speaking enquiries</li>
  </ul>

  <h2>Institutional Affiliation</h2>
  <p>
    The HAIF project is based at
    <a href="https://www.rmit.edu.au">RMIT University</a>, Melbourne, Australia.
    Dr Zhen Zheng is a Senior Research Fellow in the School of Health and
    Biomedical Sciences.
  </p>
</BaseLayout>
