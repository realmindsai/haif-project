  <div class="downloads">
    <h3>Phase 1 Resources</h3>
    <ul>
      <li><a href={url('/resources/')}>PONV risk self-assessment checklist</a></li>
      <li><a href={url('/resources/')}>PONV data extraction template (Excel)</a></li>
      <li><a href={url('/resources/')}>Modified CARI readiness checklist</a></li>
      <li><a href={url('/resources/')}>Sample staff survey questions</a></li>
      <li><a href={url('/resources/')}>Patient survey results and template</a></li>
    </ul>
  </div>

